{
  "name": "scrapping-repuestos-uy-api",
  "version": "0.1.0",
  "description": "API en NestJS para scraping hibrido de catalogos de repuestos por dominio",
  "private": true,
  "packageManager": "pnpm@11.2.2",
  "scripts": {
    "setup": "pnpm install",
    "build": "tsc -p tsconfig.build.json",
    "start": "node dist/main.js",
    "start:dev": "tsx watch src/main.ts",
    "dev": "pnpm run db:migrate && pnpm run start:dev",
    "db:up": "docker compose -f docker-compose.dev.yml up -d postgres",
    "db:down": "docker compose -f docker-compose.dev.yml down",
    "db:migrate": "DATABASE_URL=${DATABASE_URL:-postgresql://postgres:postgres@localhost:5433/repuestos_uy} node-pg-migrate up",
    "dev:local": "pnpm run db:up && pnpm run dev",
    "lint": "tsc --noEmit",
    "test": "pnpm run build && node --test \"dist/**/*.test.js\"",
    "scrape:daily": "node scripts/run-daily-scrape.mjs"
  },
  "engines": {
    "node": ">=20.11"
  },
  "dependencies": {
    "@nestjs/common": "^11.1.24",
    "@nestjs/core": "^11.1.24",
    "@nestjs/platform-express": "^11.1.24",
    "@nestjs/schedule": "^6.1.3",
    "@types/pg": "^8.20.0",
    "class-transformer": "^0.5.1",
    "class-validator": "^0.15.1",
    "dotenv": "^17.4.2",
    "node-html-parser": "^7.1.0",
    "node-pg-migrate": "8.0.4",
    "pg": "^8.21.0",
    "playwright": "^1.60.0",
    "reflect-metadata": "^0.2.2",
    "rxjs": "^7.8.2"
  },
  "devDependencies": {
    "@types/node": "^25.9.1",
    "tsx": "^4.22.4",
    "typescript": "^6.0.3"
  }
}
