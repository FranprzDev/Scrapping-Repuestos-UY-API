{
  "name": "scrapping-repuestos-uy-api",
  "version": "0.1.0",
  "description": "API en NestJS para scraping hibrido de catalogos de repuestos por dominio",
  "private": true,
  "scripts": {
    "setup": "pnpm install",
    "build": "tsc -p tsconfig.build.json",
    "start": "node dist/main.js",
    "start:dev": "ts-node-dev --respawn --transpile-only src/main.ts",
    "dev": "pnpm run start:dev",
    "lint": "tsc --noEmit",
    "test": "npm run build && node --test \"dist/**/*.test.js\"",
    "scrape:daily": "node scripts/run-daily-scrape.mjs"
  },
  "engines": {
    "node": ">=18"
  },
  "dependencies": {
    "@nestjs/common": "^10.4.2",
    "@nestjs/core": "^10.4.2",
    "@nestjs/platform-express": "^10.4.2",
    "@nestjs/schedule": "^6.1.3",
    "@types/pg": "^8.20.0",
    "cheerio": "^1.0.0",
    "class-transformer": "^0.5.1",
    "class-validator": "^0.14.1",
    "dotenv": "^17.3.1",
    "pg": "^8.21.0",
    "playwright": "^1.58.2",
    "reflect-metadata": "^0.2.2",
    "rxjs": "^7.8.1"
  },
  "devDependencies": {
    "@types/node": "^22.5.4",
    "ts-node": "^10.9.2",
    "ts-node-dev": "^2.0.0",
    "typescript": "^5.5.4"
  }
}
